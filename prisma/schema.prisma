  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("matches")
}

model Conversation {
  id                 BigInt    @id @default(autoincrement())
  matchId            BigInt    @map("match_id")
  user1Id            BigInt    @map("user1_id")
  user2Id            BigInt    @map("user2_id")
  lastMessageAt      DateTime? @map("last_message_at") @db.Timestamp(0)
  lastMessagePreview String?   @map("last_message_preview") @db.VarChar(255)
